# Required API keys
KALSHI_API_KEY_ID=your-kalshi-api-key-id
KALSHI_PRIVATE_KEY_PATH=/path/to/your-kalshi-key.key.txt
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
FRED_API_KEY=your-fred-api-key

# Email notifications (optional)
KALSHI_EMAIL_FROM=you@gmail.com
KALSHI_EMAIL_PASSWORD=your-gmail-app-password
KALSHI_EMAIL_TO=you@gmail.com

# Dashboard binding (default: 127.0.0.1)
KALSHI_DASHBOARD_HOST=127.0.0.1
