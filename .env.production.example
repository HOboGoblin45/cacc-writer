# ============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Real Brain Appraisal SaaS - Production Deployment
# ============================================================================
# Copy this file to .env.production and fill in real values for deployment
# Never commit actual secrets to version control

# ============================================================================
# APPLICATION & SERVER
# ============================================================================
NODE_ENV=production
PORT=5178
HOST=0.0.0.0
BASE_URL=https://your-domain.com

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT signing secrets - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-min-32-chars

# Encryption key for sensitive data - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CACC_ENCRYPTION_KEY=your-encryption-key-32-bytes

# ============================================================================
# DATABASE
# ============================================================================
DB_PATH=/data/cacc.db

# ============================================================================
# AI PROVIDERS & MODELS
# ============================================================================
# OpenAI API
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google AI / Gemini
GOOGLE_AI_KEY=your-google-ai-key

# ============================================================================
# RUNPOD PROPRIETARY AI ENGINE
# ============================================================================
# Fine-tuned Llama 3.1 8B deployment on RunPod
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_POD_ID=your-pod-id

# ============================================================================
# STRIPE BILLING & PAYMENTS
# ============================================================================
# Stripe keys - get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-public-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Product price IDs - created via scripts/setup-stripe-products.mjs
STRIPE_STARTER_PRICE_ID=price_starter_id_here
STRIPE_PRO_PRICE_ID=price_pro_id_here
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_id_here

# ============================================================================
# OAUTH & SOCIAL LOGIN
# ============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================
# Mercury Appraisal Software Integration
MERCURY_API_URL=https://api.mercury-appraisal.com
MERCURY_CLIENT_ID=your-mercury-client-id
MERCURY_CLIENT_SECRET=your-mercury-client-secret

# SendGrid Email Service
SENDGRID_API_KEY=SG.your-sendgrid-key
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=Real Brain Appraisals

# ============================================================================
# VECTOR DATABASE & SEMANTIC SEARCH
# ============================================================================
# Pinecone vector embeddings for Knowledge Brain
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=realbrain-prod
PINECONE_ENVIRONMENT=us-east-1-aws

# ============================================================================
# MONITORING & ERROR TRACKING
# ============================================================================
# Sentry - error and performance monitoring
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# Application logging
LOG_LEVEL=info
