# ─────────────────────────────────────────────────────────────────────────────
# CACC Writer — Production Environment Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values before deploying.
#
#   cp .env.production.template .env
#   # Edit .env with production values
#   docker compose -f docker-compose.production.yml up -d
#
# REQUIRED values are marked [REQUIRED]. The server will refuse to start
# in production without them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5178

# [REQUIRED] JWT signing secret — at least 32 characters, randomly generated
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# [REQUIRED] Master encryption key for PII at rest — at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
CACC_ENCRYPTION_KEY=

# ── AI Providers ─────────────────────────────────────────────────────────────
# Primary AI provider: openai | gemini | ollama
AI_PROVIDER=openai

# OpenAI API key (starts with sk-)
OPENAI_API_KEY=

# Google Gemini API key (optional, for fallback)
GEMINI_API_KEY=

# ── Proprietary Model (RunPod) ──────────────────────────────────────────────
# RunPod pod ID for fine-tuned Llama model
RUNPOD_POD_ID=
RUNPOD_API_KEY=

# ── Stripe Billing ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Application URL ─────────────────────────────────────────────────────────
# Public URL where the app is hosted (for CORS, redirects, etc.)
APP_URL=https://appraisal-agent.com

# ── Database ─────────────────────────────────────────────────────────────────
# Override default SQLite path (default: data/cacc-writer.db)
# CACC_DB_PATH=/app/data/cacc-writer.db

# ── Feature Flags ────────────────────────────────────────────────────────────
# Skip automatic QC after generation (default: run QC)
# CACC_SKIP_AUTO_QC=0

# Allow force gate bypass in workflows (default: disabled in production)
# CACC_ALLOW_FORCE_GATE_BYPASS=0

# Max parallel AI section jobs (default: 5)
# MAX_PARALLEL_SECTIONS=5

# Graceful shutdown timeout in ms (default: 10000)
# SHUTDOWN_TIMEOUT_MS=10000
