# ══════════════════════════════════════════════════════════════════════════════
# CACC Writer v2.0 — Environment Variables
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# OpenAI API key (required for all AI generation)
OPENAI_API_KEY=sk-...

# OpenAI model (default: gpt-4.1)
OPENAI_MODEL=gpt-4.1

# ── SERVER ────────────────────────────────────────────────────────────────────

# Server port (default: 5178)
PORT=5178

# ── THROUGHPUT TUNING ─────────────────────────────────────────────────────

# Max concurrent OpenAI API requests (default: 8)
OPENAI_MAX_CONCURRENT=8

# Max parallel section drafting jobs in the orchestrator (default: 5)
MAX_PARALLEL_SECTIONS=5

# Max parallel fields per batch in the LangGraph workflow (default: 3)
WORKFLOW_BATCH_PARALLEL=3

# ── AUTOMATION AGENTS ─────────────────────────────────────────────────────────

# ACI desktop agent URL (default: http://localhost:5180)
# Start with: python desktop_agent/agent.py
ACI_AGENT_URL=http://localhost:5180

# ACI agent timeout in ms (default: 20000)
ACI_TIMEOUT_MS=20000

# Real Quantum browser agent URL (default: http://localhost:5181)
# Start with: python real_quantum_agent/agent.py
RQ_AGENT_URL=http://localhost:5181

# Real Quantum agent timeout in ms (default: 30000)
RQ_TIMEOUT_MS=30000

# ── NEW ARCHITECTURE: PINECONE (optional — falls back to local KB) ─────────────

# Pinecone API key
# Get from: https://app.pinecone.io/
PINECONE_API_KEY=pcsk_...

# Pinecone index name (create this index in Pinecone dashboard)
# Dimensions: 1536 (text-embedding-3-small)
# Metric: cosine
PINECONE_INDEX_NAME=cacc-writer

# Pinecone environment (e.g. us-east-1-aws)
PINECONE_ENVIRONMENT=us-east-1-aws

# ── NEW ARCHITECTURE: LANGSMITH TRACING (optional) ────────────────────────────

# Enable LangSmith tracing
# Set to 'true' to enable (requires LANGCHAIN_API_KEY)
LANGCHAIN_TRACING_V2=false

# LangSmith API key
# Get from: https://smith.langchain.com/
LANGCHAIN_API_KEY=ls__...

# LangSmith project name (groups traces together)
LANGCHAIN_PROJECT=cacc-writer

# LangSmith endpoint (default: https://api.smith.langchain.com)
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── NEW ARCHITECTURE: LANGFUSE OBSERVABILITY (optional) ───────────────────────

# Langfuse public key
# Get from: https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=pk-lf-...

# Langfuse secret key
LANGFUSE_SECRET_KEY=sk-lf-...

# Langfuse host (default: https://cloud.langfuse.com)
# Use http://localhost:3000 for self-hosted Langfuse
LANGFUSE_HOST=https://cloud.langfuse.com

# ── LEGACY (kept for backward compatibility) ──────────────────────────────────

# Modular server port (legacy — not used in production)
MODULAR_PORT=5179

# ── AI PROVIDER (Local AI) ────────────────────────────────────────────────────

# Switch between OpenAI and local Ollama AI
# 'openai' = OpenAI cloud API (requires OPENAI_API_KEY)
# 'ollama' = Local AI via Ollama (free, no API key needed)
AI_PROVIDER=openai

# Ollama model to use (when AI_PROVIDER=ollama)
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M

# Ollama API URL (default: http://127.0.0.1:11434)
OLLAMA_URL=http://127.0.0.1:11434

# ── AUTHENTICATION ────────────────────────────────────────────────────────────

# Enable multi-tenant auth (set to 'true' for SaaS mode)
# 'false' = single-user mode (backward compatible, no login required)
CACC_AUTH_ENABLED=false

# JWT secret for token signing (auto-generated if not set)
# IMPORTANT: Set this in production! Random secret = tokens invalidated on restart.
JWT_SECRET=

# JWT token expiration (default: 7d)
JWT_EXPIRES_IN=7d

# Legacy API key (backward compat for single-user mode)
CACC_API_KEY=

# ── STRIPE BILLING ────────────────────────────────────────────────────────────

# Stripe secret key (from Stripe Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs for each plan (create these in Stripe Dashboard > Products)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# App URL (for Stripe redirect URLs)
APP_URL=http://localhost:5178

# ── USPS ADDRESS VERIFICATION ─────────────────────────────────────────────────

# USPS Addresses 3.0 API (free — register at developers.usps.com)
# Validates and standardizes addresses against USPS records
# Adds ZIP+4, corrects typos, confirms deliverability
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=

# ── PLATFORM AI (Proprietary Features) ────────────────────────────────────────

# Platform Gemini API key — powers FREE built-in features for ALL users:
#   • PDF document extraction (order forms, MLS sheets, tax records)
#   • Photo AI analysis (condition/quality detection)
#   • Document classification
#   • Smart upload (auto-detect document type)
#
# This is YOUR platform key, NOT the user's. Users don't need their own
# AI key to use these features — they're included in the platform.
#
# Cost: ~$0.0002 per PDF extraction. At 1000 users × 30 PDFs/mo = ~$6/month.
# Get key at: https://aistudio.google.com/apikey
PLATFORM_GEMINI_KEY=

# Google Gemini API key (for user-selected Gemini as their generation provider)
# This is separate from PLATFORM_GEMINI_KEY
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
