            document.getElementById('tooltip-title').textContent = d.name;
            document.getElementById('tooltip-content').innerHTML = `
                <strong>Type:</strong> ${d.type}<br>
                <strong>Connections:</strong> ${d.connections || 0}<br>
                ${d.description ? `<strong>Description:</strong> ${d.description}` : ''}
            `;
            tooltip.style.display = 'block';
            tooltip.style.left = event.pageX + 10 + 'px';
            tooltip.style.top = event.pageY + 10 + 'px';
        }

        function hideTooltip() {
            document.getElementById('tooltip').style.display = 'none';
        }

