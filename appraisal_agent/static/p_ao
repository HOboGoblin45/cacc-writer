ener('keypress', (e) => {
                if (e.key === 'Enter') sendChatMessage();
            });

            // Comps
            document.getElementById('gather-comps-btn').addEventListener('click', async () => {
                showThinking('Searching MLS for comparable properties');
                const result = await apiCall('/api/comps', { method: 'POST', body: JSON.stringify({}) });
                loadComps();
            });

            // Report
            document.getElementById('confirm-export-btn').addEventListener('click', async () => {
                const result = await apiCall('/api/report/export', {
                    method: 'POST',
                    body: JSON.stringify({ format: 'pdf' })
                });
                if (result) {
                    alert('Report exported successfully!');
                }
            });

            // Buttons
            document.getElementById('new-appraisal-btn').addEventListener('click', async () => {
                const result = await apiCall('/api/appraisal/new', { method: 'POST', body: JSON.stringify({}) });
                loadGraph();
                addChatMessage('agent', 'New appraisal started! Please tell me about the property you\'d like to appraise.');
            });

            document.getElementById('refresh-graph-btn').addEventListener('click', loadGraph);

            // Node details panel close
            document.getElementById('close-panel-btn').addEventListener('click', () => {
                document.getElementById('node-details-panel').classList.remove('open');
            });

            // Search
            document.getElementById('search-input').addEventListener('keyup', (e) => {
                const query = e.target.value;
                if (query.length > 0) {
                    searchNodes(query);
                }
            });
        }

        async function searchNodes(query) {
            const results = await apiCall(`/api/graph/search?q=${encodeURIComponent(query)}`);
            if (results && results.length > 0) {
                selectNode(results[0]);
            }
        }

        function updateConnectionStatus(connected = false) {
            const statusDot = document.getElementById('connection-status');
            const statusText = document.getElementById('connection-text');
            if (connected) {
                statusDot.classList.remove('disconnected');
                statusText.textContent = 'Connected';
            } else {
                statusDot.classList.add('disconnected');
                statusText.textContent = 'Disconnected';
            }
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // ============ Initialize on Load ============
        document.addEventListener('DOMContentLoaded', initializeApp);
    </script>
</body>
</html>
