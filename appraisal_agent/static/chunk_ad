art();
            d.fx = d.x;
            d.fy = d.y;
        }

        function dragged(event, d) {
            d.fx = event.x;
            d.fy = event.y;
        }

        function dragEnded(event, d) {
            if (!event.active) simulation.alphaTarget(0);
            d.fx = null;
            d.fy = null;
        }

        function selectNode(node) {
            selectedNode = node;
            d3.selectAll('.node').classed('selected', d => d.id === node.id);
            showNodeDetails(node);
        }

        function showTooltip(event, d) {
            const tooltip = document.getElementById('tooltip');
            document.getElementById('tooltip-title').textContent = d.name;
            document.getElementById('tooltip-content').innerHTML = `
                <strong>Type:</strong> ${d.type}<br>
                <strong>Connections:</strong> ${d.connections || 0}<br>
                ${d.description ? `<strong>Description:</strong> ${d.description}` : ''}
            `;
            tooltip.style.display = 'block';
            tooltip.style.left = event.pageX + 10 + 'px';
            tooltip.style.top = event.pageY + 10 + 'px';
        }

        function hideTooltip() {
            document.getElementById('tooltip').style.display = 'none';
        }

        function showNodeDetails(node) {
            const panel = document.getElementById('node-details-panel');
            document.getElementById('node-details-type').textContent = node.type;
            document.getElementById('node-details-name').textContent = node.name;

            // Properties
            const propsDiv = document.getElementById('node-details-properties');
            propsDiv.innerHTML = '<div class="details-section-title">Properties</div>';
            if (node.properties) {
                Object.entries(node.properties).forEach(([key, value]) => {
                    const item = document.createElement('div');
                    item.className = 'details-item';
                    item.innerHTML = `<span class="details-label">${key}:</span><span class="details-value">${value}</span>`;
                    propsDiv.appendChild(item);
                });
            }

            // Connections
            const connections = graphData.edges.filter(e => e.source.id === node.id || e.target.id === node.id);
            const connDiv = document.getElementById('node-connections');
            connDiv.innerHTML = '';
            connections.forEach(edge => {
                const related = edge.source.id === node.id ? edge.target : edge.source;
                const item = document.createElement('div');
                item.className = 'connection-item';
                item.innerHTML = `
                    <div class="connection-relation">${edge.relation || 'connected'}</div>
                    <div class="connection-target">${related.name}</div>
                `;
                item.onclick = () => selectNode(related);
                connDiv.appendChild(item);
            });

            panel.classList.add('open');
        }

        function filterByNodeType(type) {
            const filtered = graphData.nodes.filter(n => n.type === type);
            if (filtered.length > 0) {
                selectNode(filtered[0]);
            }
        }

        // ============ Chat & WebSocket ============
        let ws = null;

        function setupWebSocket() {
            const protocol = window.location.protocol === 'https:' ? 'wss' : 'ws';
            const wsUrl = `${protocol}://${window.location.host}/ws/chat`;

            ws = new WebSocket(wsUrl);

            ws.onopen = () => {
                updateConnectionStatus(true);
            };

            ws.onmessage = (event) => {
                const data = JSON.parse(event.data);
                if (data.type === 'message') {
                    addChatMessage('agent', data.content);
                } else if (data.type === 'thinking') {
                    showThinking(data.action);
                } else if (data.type === 'graph_update') {
                    loadGraph();
                }
            };

            ws.onclose = () => {
                updateConnectionStatus(false);
            };
        }

        function addChatMessage(sender, content) {
            const messagesDiv = document.getElementById('chat-messages');
            const messageEl = document.createElement('div');
            messageEl.className = `message ${sender}`;
            messageEl.innerHTML = `<div class="message-bubble">${escapeHtml(content)}</div>`;
            messagesDiv.appendChild(messageEl);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        function showThinking(action) {
            const messagesDiv = document.getElementById('chat-messages');
            const messageEl = document.createElement('div');
            messageEl.className = 'message agent';
            messageEl.innerHTML = `
                <div class="thinking-indicator">
                    <span>${action}...</span>
                    <div class="thinking-dot"></div>
                    <div class="thinking-dot"></div>
                    <div class="thinking-dot"></div>
                </div>
            `;
            messagesDiv.appendChild(messageEl);
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }

        function sendChatMessage() {
            const input = document.getElementById('chat-input');
            const message = input.value.trim();
            if (!message) return;

            addChatMessage('user', message);
            input.value = '';

            if (ws && ws.readyState === WebSocket.OPEN) {
                ws.send(JSON.stringify({
                    type: 'message',
                    content: message
                }));
            }
        }

        // ============ Market Data ============
        async function loadMarketData() {
            const data = await apiCall('/api/market');
            if (data) {
                document.getElementById('market-median').textContent = `$${data.median_price?.toLocaleString() || '--'}`;
                document.getElementById('market-dom').textContent = data.days_on_market || '--';
                document.getElementById('market-inventory').textContent = data.inventory || '--';
                document.getElementById('market-trend').textContent = data.price_trend ? `${data.price_trend > 0 ? '+' : ''}${data.price_trend.toFixed(1)}%` : '--';

                if (data.median_change) {
                    const elem = document.getElementById('market-median-change');
                    elem.textContent = `${data.median_change > 0 ? '↑' : '↓'} ${Math.abs(data.median_change).toFixed(1)}%`;
                    elem.className = `market-card-change ${data.median_change > 0 ? 'positive' : 'negative'}`;
                }
            }
        }

        // ============ Comparable Sales ============
        async function loadComps() {
            const data = await apiCall('/api/comps');
            if (data && data.length > 0) {
                const tbody = document.getElementById('comps-table-body');
                tbody.innerHTML = data.map(comp => `
                    <tr>
                        <td>${comp.address}</td>
                        <td>$${comp.sale_price?.toLocaleString()}</td>
                        <td>${comp.sale_date}</td>
                        <td>${comp.sqft?.toLocaleString()}</td>
                        <td>${comp.beds}</td>
                        <td>${comp.baths}</td>
                        <td>${comp.distance?.toFixed(1)} mi</td>
                        <td>$${comp.adjustments?.toLocaleString() || '0'}</td>
                        <td>$${comp.adjusted_price?.toLocaleString()}</td>
                    </tr>
                `).join('');
            }
        }

        // ============ Report Preview ============
        async function loadReportData() {
            const data = await apiCall('/api/report/preview');
            if (data) {
                // Subject property
                document.getElementById('report-subject-address').textContent = data.subject?.address || '--';
                document.getElementById('report-subject-type').textContent = data.subject?.type || '--';
                document.getElementById('report-subject-sqft').textContent = data.subject?.sqft?.toLocaleString() || '--';
                document.getElementById('report-subject-beds').textContent = data.subject?.beds || '--';
                document.getElementById('report-subject-baths').textContent = data.subject?.baths || '--';

                // Neighborhood
                document.getElementById('report-neighborhood').textContent = data.neighborhood?.market_area || '--';
                document.getElementById('report-school-district').textContent = data.neighborhood?.school_district || '--';
                document.getElementById('report-condition').textContent = data.neighborhood?.condition || '--';

                // Market
                document.getElementById('report-market-type').textContent = data.market?.type || '--';
                document.getElementById('report-median-price').textContent = `$${data.market?.median_price?.toLocaleString() || '--'}`;
                document.getElementById('report-days-market').textContent = data.market?.days_on_market || '--';

                // Reconciliation
                document.getElementById('report-approach1').textContent = `$${data.approaches?.comp_approach?.toLocaleString() || '--'}`;
                document.getElementById('report-approach2').textContent = `$${data.approaches?.cost_approach?.toLocaleString() || '--'}`;
                document.getElementById('report-approach3').textContent = `$${data.approaches?.income_approach?.toLocaleString() || '--'}`;
                document.getElementById('report-final-value').textContent = `$${data.final_value?.toLocaleString() || '--'}`;
            }
        }

        // ============ UI Event Listeners ============
        function setupUIEventListeners() {
            // Tab switching
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
                    document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));

                    btn.classList.add('active');
                    const tabId = btn.getAttribute('data-tab');
                    document.getElementById(tabId).classList.add('active');

                    if (tabId === 'comps-tab') loadComps();
                    if (tabId === 'report-tab') loadReportData();
                });
            });

            // Chat
            document.getElementById('chat-send-btn').addEventListener('click', sendChatMessage);
            document.getElementById('chat-input').addEventListener('keypress', (e) => {
                if (e.key === 'Enter') sendChatMessage();
            });

            // Comps
            document.getElementById('gather-comps-btn').addEventListener('click', async () => {
                showThinking('Searching MLS for comparable properties');
                const result = await apiCall('/api/comps', { method: 'POST', body: JSON.stringify({}) });
                loadComps();
            });

            // Report
            document.getElementById('confirm-export-btn').addEventListener('click', async () => {
                const result = await apiCall('/api/report/export', {
                    method: 'POST',
                    body: JSON.stringify({ format: 'pdf' })
                });
                if (result) {
                    alert('Report exported successfully!');
                }
            });

            // Buttons
            document.getElementById('new-appraisal-btn').addEventListener('click', async () => {
                const result = await apiCall('/api/appraisal/new', { method: 'POST', body: JSON.stringify({}) });
                loadGraph();
                addChatMessage('agent', 'New appraisal started! Please tell me about the property you\'d like to appraise.');
            });

            document.getElementById('refresh-graph-btn').addEventListener('click', loadGraph);

            // Node details panel close
            document.getElementById('close-panel-btn').addEventListener('click', () => {
                document.getElementById('node-details-panel').classList.remove('open');
            });

            // Search
            document.getElementById('search-input').addEventListener('keyup', (e) => {
                const query = e.target.value;
                if (query.length > 0) {
                    searchNodes(query);
                }
            });
        }

        async function searchNodes(query) {
            const results = await apiCall(`/api/graph/search?q=${encodeURIComponent(query)}`);
            if (results && results.length > 0) {
                selectNode(results[0]);
            }
        }

        function updateConnectionStatus(connected = false) {
            const statusDot = document.getElementById('connection-status');
            const statusText = document.getElementById('connection-text');
            if (connected) {
                statusDot.classList.remove('disconnected');
                statusText.textContent = 'Connected';
            } else {
                statusDot.classList.add('disconnected');
                statusText.textContent = 'Disconnected';
            }
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // ============ Initialize on Load ============
        document.addEventListener('DOMContentLoaded', initializeApp);
    </script>
</body>
</html>
