        }

        .report-label {
            color: #888;
        }

        .report-value {
            color: #e0e0e0;
            font-weight: 600;
        }

        .report-footer {
            display: flex;
            gap: 8px;
            margin-top: 20px;
        }

        .report-footer .btn {
            flex: 1;
        }

        /* Node Details Panel */
        .node-details-panel {
            position: fixed;
            right: 0;
            top: 70px;
            width: 350px;
            height: calc(100vh - 70px);
            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
            border-left: 2px solid #e94560;
            transform: translateX(100%);
            transition: transform 0.3s ease;
            overflow-y: auto;
            z-index: 500;
            box-shadow: -4px 0 12px rgba(0, 0, 0, 0.5);
        }

        .node-details-panel.open {
            transform: translateX(0);
        }

        .node-details-header {
            padding: 20px;
            border-bottom: 2px solid #0f3460;
            display: flex;
            justify-content: space-between;
            align-items: start;
        }

        .node-details-title {
            flex: 1;
        }

        .node-details-type {
            display: inline-block;
            background: rgba(233, 69, 96, 0.2);
            border: 1px solid #e94560;
            border-radius: 4px;
            padding: 4px 8px;
            font-size: 10px;
            color: #ff6b9d;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .node-details-name {
            font-size: 18px;
            font-weight: 700;
            color: #fff;
        }

        .close-panel-btn {
            background: none;
            border: none;
            color: #888;
            font-size: 20px;
            cursor: pointer;
            padding: 4px;
            transition: color 0.2s ease;
        }

        .close-panel-btn:hover {
            color: #e94560;
        }

        .node-details-content {
            padding: 20px;
        }

        .details-section {
            margin-bottom: 20px;
        }

        .details-section-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            color: #888;
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }

        .details-item {
            font-size: 12px;
            padding: 6px 0;
            color: #ccc;
        }

        .details-label {
            color: #888;
            margin-right: 8px;
        }

        .details-value {
            color: #e0e0e0;
            font-weight: 600;
        }

        .connections-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .connection-item {
            background: rgba(15, 52, 96, 0.4);
            border: 1px solid #0f3460;
            border-radius: 4px;
            padding: 8px;
            font-size: 11px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .connection-item:hover {
            background: rgba(233, 69, 96, 0.2);
            border-color: #e94560;
        }

        .connection-relation {
            color: #ff6b9d;
            font-weight: 600;
        }

        .connection-target {
            color: #ccc;
            margin-top: 4px;
        }

        /* Scrollbar styling */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(15, 52, 96, 0.2);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(233, 69, 96, 0.5);
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(233, 69, 96, 0.7);
        }

        /* Responsive adjustments */
        @media (max-width: 1400px) {
            .market-cards {
                grid-template-columns: 1fr;
            }

            .message {
                max-width: 80%;
            }
        }

        @media (max-width: 1024px) {
            .container {
                grid-template-columns: 250px 1fr;
            }

            .node-details-panel {
                width: 300px;
            }
        }
    </style>
</head>
