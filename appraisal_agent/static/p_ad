        .chat-input-box {
            display: flex;
            gap: 8px;
            background: rgba(15, 52, 96, 0.3);
            border: 1px solid #0f3460;
            border-radius: 8px;
            padding: 8px;
        }

        .chat-input {
            flex: 1;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 13px;
            font-family: inherit;
        }

        .chat-input:focus {
            outline: none;
        }

        .chat-input::placeholder {
            color: #666;
        }

        .chat-send-btn {
            background: #e94560;
            border: none;
            color: #fff;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 600;
            font-size: 12px;
            transition: all 0.2s ease;
        }

        .chat-send-btn:hover {
            background: #ff6b9d;
            box-shadow: 0 0 8px rgba(233, 69, 96, 0.4);
        }

        .chat-send-btn:disabled {
            background: #666;
            cursor: not-allowed;
            opacity: 0.5;
        }

        /* Comps Tab */
        .comps-table-wrapper {
            flex: 1;
            overflow: auto;
        }

        .comps-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

        .comps-table thead {
            background: rgba(15, 52, 96, 0.5);
            position: sticky;
            top: 0;
        }

        .comps-table th {
            padding: 12px;
            text-align: left;
            color: #ff6b9d;
            font-weight: 600;
            border-bottom: 2px solid #0f3460;
        }

        .comps-table td {
            padding: 12px;
            border-bottom: 1px solid #0f3460;
            color: #e0e0e0;
        }

        .comps-table tbody tr:hover {
            background: rgba(233, 69, 96, 0.1);
        }

        .comps-button-group {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
        }

        .btn {
            background: #e94560;
            border: none;
            color: #fff;
            padding: 10px 16px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 13px;
            transition: all 0.2s ease;
        }

        .btn:hover {
            background: #ff6b9d;
            box-shadow: 0 0 8px rgba(233, 69, 96, 0.4);
        }

        .btn.secondary {
            background: rgba(15, 52, 96, 0.5);
            border: 1px solid #0f3460;
            color: #ff6b9d;
        }

        .btn.secondary:hover {
            background: rgba(233, 69, 96, 0.2);
            border-color: #e94560;
        }

        /* Market Data Tab */
        .market-cards {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .market-card {
            background: linear-gradient(135deg, rgba(15, 52, 96, 0.4) 0%, rgba(9, 30, 66, 0.2) 100%);
            border: 1px solid #0f3460;
            border-radius: 8px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .market-card-label {
            color: #888;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .market-card-value {
            font-size: 28px;
            font-weight: 700;
            color: #ff6b9d;
        }

        .market-card-change {
            font-size: 12px;
            color: #888;
        }

        .market-card-change.positive {
            color: #0f0;
        }

        .market-card-change.negative {
            color: #f00;
        }

