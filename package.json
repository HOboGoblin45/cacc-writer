{
  "name": "appraisal-agent",
  "version": "3.1.0",
  "type": "module",
  "main": "desktop/electron/main.cjs",
  "scripts": {
    "start": "node cacc-writer-server.js",
    "start:all": "start-all.bat",
    "dev": "node --watch cacc-writer-server.js",
    "start:electron": "electron .",
    "package:electron": "electron-forge package --config desktop/forge.config.cjs",
    "make": "electron-forge make --config desktop/forge.config.cjs",
    "test": "vitest run",
    "test:syntax": "vitest run tests/vitest/syntax.test.mjs",
    "test:smoke": "node tests/integration/_test_smoke.mjs",
    "test:upload": "node tests/integration/_test_upload.mjs",
    "test:desktop": "node tests/integration/_test_desktop_endpoints.mjs",
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "workflow:dev": "tsx server/workflow/appraisalWorkflow.ts",
    "validate:registry": "node scripts/validateFieldRegistry.js",
    "test:unit": "node tests/unit/run.mjs",
    "test:unit:vitest": "vitest run",
    "test:golden": "node scripts/runGoldenPath.mjs",
    "test:golden:preflight": "node scripts/runGoldenPath.mjs --allow-dry-run-insertion --cleanup",
    "test:golden:1004": "node scripts/runGoldenPath.mjs --fixture fixtures/golden/1004-case",
    "test:golden:commercial": "node scripts/runGoldenPath.mjs --fixture fixtures/golden/commercial-case",
    "benchmark:phase-c": "node scripts/runPhaseCBenchmarks.mjs",
    "benchmark:phase-c:check": "node scripts/checkPhaseCBenchmarkThresholds.mjs",
    "test:all": "vitest run && npm run test:smoke",
    "ci:check": "npm run typecheck && vitest run && npm run benchmark:phase-c:check && npm run test:smoke",
    "test:ci": "node scripts/ci-local.mjs"
  },
  "dependencies": {
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/openai": "^1.2.12",
    "@napi-rs/canvas": "^0.1.96",
    "@pinecone-database/pinecone": "^7.1.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "langfuse": "^3.0.0",
    "langsmith": "^0.5.9",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "openai": "^6.27.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.296",
    "pdfkit": "^0.18.0",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18.0.0 <25.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "electron": "^41.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
