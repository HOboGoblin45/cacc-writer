{
  "name": "cacc-writer",
  "version": "2.0.0",
  "type": "module",
  "main": "desktop/electron/main.cjs",
  "scripts": {
    "start": "node cacc-writer-server.js",
    "dev": "node --watch cacc-writer-server.js",
    "start:electron": "electron .",
    "package:electron": "electron-forge package --config desktop/forge.config.cjs",
    "make": "electron-forge make --config desktop/forge.config.cjs",
    "test": "node _test_smoke.mjs",
    "test:smoke": "node _test_smoke.mjs",
    "test:upload": "node _test_upload.mjs",
    "test:desktop": "node _test_desktop_endpoints.mjs",
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "workflow:dev": "tsx server/workflow/appraisalWorkflow.ts",
    "validate:registry": "node scripts/validateFieldRegistry.js",
    "test:unit": "node tests/unit/run.mjs",
    "test:all": "node tests/unit/run.mjs && node _test_smoke.mjs"
  },
  "dependencies": {
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/openai": "^1.2.12",
    "@napi-rs/canvas": "^0.1.96",
    "@pinecone-database/pinecone": "^7.1.0",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "langfuse": "^3.0.0",
    "langsmith": "^0.5.9",
    "multer": "^2.1.1",
    "openai": "^6.27.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.296",
    "uuid": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "electron": "^41.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
